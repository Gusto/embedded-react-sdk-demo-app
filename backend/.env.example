# Gusto OAuth Credentials
CLIENT_ID=your_client_id_here
CLIENT_SECRET=your_client_secret_here

# Optional: Defaults to https://api.gusto-demo.com
GUSTO_API_BASE_URL=https://api.gusto-demo.com

# Optional: refresh token fallback for environments that inject secrets as env
# vars instead of using a tokens.json file (e.g. Cursor cloud agents / CI).
# Used only to seed the initial token when backend/tokens.json is absent; the
# rotated token is still persisted to tokens.json during the run.
# GUSTO_REFRESH_TOKEN=your_refresh_token_here
