# Gusto OAuth Credentials
CLIENT_ID=your_client_id_here
CLIENT_SECRET=your_client_secret_here

# Optional: Defaults to https://api.gusto-demo.com
GUSTO_API_BASE_URL=https://api.gusto-demo.com

# Optional: Extra browser origins allowed through CORS, comma-separated.
# The proxy already allows localhost by default; add others here if needed.
# ALLOWED_ORIGINS=https://app.example.com,https://staging.example.com
